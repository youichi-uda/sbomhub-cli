# SBOMHub CLI - source-mode bench variant (M4-7 / M5-2)
#
# The default `Dockerfile` produces a slim `alpine:3.19 + ca-certificates`
# runtime image. Since M5-2, that image can run `sbomhub llm bench` in
# the default binary mode: the CLI downloads the pre-built llm-bench
# release archive, verifies it against checksums.txt, caches it under
# ~/.cache/sbomhub-cli/llm-bench, and execs the binary directly.
#
# This variant image is retained for SBOMHUB_BENCH_MODE=source, where
# operators intentionally compile llm-bench from a local sbomhub OSS
# checkout (offline custom builds, pre-release upstream testing, or
# source-level debugging). It bundles Go + git for that compatibility
# path. The trade-off is image size (~300MB vs ~15MB for the slim
# default), so this remains a separate tag (`sbomhub-cli:bench`).
#
# `sbomhub llm test`, binary-mode `sbomhub llm bench`, and every other
# subcommand work on the default slim image; only source-mode bench
# needs this variant.
#
# M4 Codex review #F56: bumped from golang:1.22-alpine to
# golang:1.25-alpine to match the sbomhub OSS source's go.mod (apps/api
# requires `go 1.25.0`). The previous 1.22 base ran the wrapper fine
# (the CLI itself only needs 1.22+) but `sbomhub llm bench` shells out
# to `go build ./cmd/llm-bench` inside the operator's sbomhub checkout,
# and that subprocess refuses to start with:
#   go: go.mod requires go >= 1.25.0 (running go 1.22.12; GOTOOLCHAIN=local)
# Alpine images set GOTOOLCHAIN=local so the in-tree 1.22 toolchain
# does not auto-download 1.25, which made the bench-variant image's
# core workflow unrunnable. Bumping the base is the simplest fix —
# `GOTOOLCHAIN=auto` would force a multi-hundred-MB toolchain download
# on first run, which is worse than baking 1.25 in. ※要確認: when
# sbomhub apps/api's go.mod is bumped again (1.26, 1.27, ...) this
# base tag must move in lockstep.
FROM golang:1.25-alpine

WORKDIR /app

# git is required for `go build` to resolve module deps on a cold
# cache. ca-certificates is required for HTTPS calls to LLM provider
# endpoints (OpenAI / Anthropic / Gemini / Azure / Ollama).
RUN apk add --no-cache git ca-certificates

# Build the CLI from source.
#
# M5-4 cache strategy (sbomhub-cli #6): BuildKit `--mount=type=cache`
# is wired on both the module-download and the `go build` steps so a
# warm CI cache (GHA `type=gha,mode=max` backend — see
# `.github/workflows/ci.yml` docker-smoke job) reuses the previously
# downloaded module set + the build artefact cache instead of pulling
# every transitive dep + recompiling the standard library on every
# push. The mount targets match `golang:1.25-alpine`'s defaults:
#
#   GOMODCACHE = /go/pkg/mod
#   GOCACHE    = /root/.cache/go-build
#
# Confirmed via `docker run --rm golang:1.25-alpine go env`. These
# are layer-private cache volumes (BuildKit `RUN --mount=type=cache`),
# NOT image layers — so the resulting `sbomhub-cli:ci-bench` /
# `:bench` image stays the same size as before, only build time
# changes. ※要確認: when the base image is bumped (1.26+, see the
# F56 note above) re-verify these paths with `go env`.
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download

COPY . .

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux go build -o /usr/local/bin/sbomhub ./cmd/sbomhub

# Config directory matches the default image.
RUN mkdir -p /root/.sbomhub

# Default to a working directory the operator can mount the sbomhub
# OSS source into for source mode. Usage:
#
#   docker run --rm \
#     -v "$(pwd)/sbomhub:/workspace/sbomhub" \
#     -e SBOMHUB_BENCH_MODE=source \
#     -e OPENAI_API_KEY \
#     -e ANTHROPIC_API_KEY \
#     -e GOOGLE_API_KEY \
#     ghcr.io/youichi-uda/sbomhub-cli:bench \
#     llm bench --sbomhub-source /workspace/sbomhub
#
# The mount should be read-write because `go build` writes build artefacts
# into $GOCACHE (defaults to /root/.cache/go-build inside the container
# — outside the mount — but module resolution may also update go.sum on cold
# module resolution).
WORKDIR /workspace

ENTRYPOINT ["sbomhub"]
CMD ["llm", "bench", "--help"]
